{
    "name": "voxta-minecraft-companion",
    "version": "0.4.0",
    "description": "AI-powered Minecraft companion using Voxta and Mineflayer",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "start": "electron-vite dev",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --check src/",
        "format:fix": "prettier --write src/",
        "pack": "electron-vite build && electron-builder --dir",
        "dist": "electron-vite build && electron-builder"
    },
    "build": {
        "appId": "com.voxta.minecraft-companion",
        "productName": "Voxta Minecraft Companion",
        "icon": "resources/icon.png",
        "directories": {
            "output": "release"
        },
        "files": [
            "out/**/*"
        ],
        "extraResources": [
            {
                "from": "plugins/voxta-voice-bridge/build/libs/voxta-voice-bridge-1.0.0.jar",
                "to": "plugins/voxta-voice-bridge-1.0.0.jar"
            }
        ],
        "asarUnpack": [
            "node_modules/mineflayer/**",
            "node_modules/mineflayer-pathfinder/**"
        ],
        "win": {
            "target": [
                "nsis",
                "zip"
            ],
            "icon": "resources/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "resources/icon.ico",
            "uninstallerIcon": "resources/icon.ico",
            "installerHeaderIcon": "resources/icon.ico"
        }
    },
    "dependencies": {
        "@microsoft/signalr": "^9.0.0",
        "bootstrap-icons": "^1.13.1",
        "extendable-media-recorder": "^9.2.36",
        "extendable-media-recorder-wav-encoder": "^7.0.136",
        "marked": "^18.0.0",
        "mineflayer": "^4.35.0",
        "mineflayer-pathfinder": "^2.4.5"
    },
    "devDependencies": {
        "@electron-toolkit/preload": "^3.0.1",
        "@electron-toolkit/utils": "^4.0.0",
        "@eslint/js": "^10.0.1",
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8",
        "electron-vite": "^2.3.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "solid-js": "^1.9.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.56.1",
        "vite": "^5.0.0",
        "vite-plugin-solid": "^2.11.0"
    }
}
